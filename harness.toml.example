[network]
name = "esmeralda"
base_node_http_url = "https://rpc.esmeralda.tari.com"

[benchmark]
a_fund = "10000 T"
c_min = 3
volume_target = 512
doubling_rounds = 6
fanout_outputs_per_tx = 8
concurrent_batches = [8, 16, 32, 64, 128]
s4_t_budget_secs = 900
# Omit settle_wait_blocks to use max(C_min + 1, 4).
# settle_wait_blocks = 4
settle_cooldown_secs = 60
s5_m = 100
s5_k = 10
fee_rate = "5 uT"
repetitions = 3
scan_batch_size = 1000
mode1_live_topology = false
mode1_scenario_amount = "1 T"
mode1_live_max_s1_txs = 0
mode1_live_max_s4_batch = 0
mode1_live_max_s5_items = 0
live_fresh_scan_cells = false
mode2_send_smoke = false
mode2_send_smoke_amount = "1 T"
mode2_live_scenarios = false
mode2_scenario_amount = "1 T"
mode2_live_max_s1_txs = 0
mode2_live_max_s4_batch = 0
mode2_live_max_s5_txs = 0
mode3_live_topology = false
mode3_scenario_amount = "1 T"
mode3_live_max_s1_batches = 0
mode3_live_max_s4_batch = 0
mode3_live_max_s5_items = 0
mode3_worker_sleep_secs = 1

[paths]
data_dir = ".bench-data"
cache_dir = ".bench-cache"
minotari_console_wallet = "tools/minotari_console_wallet"
minotari_binary = "tools/minotari"
payment_processor_binary = ".bench-cache/minotari_payment_processor/target/release/minotari_payment_processor"

[seeds]
old_wallet_env = "HARNESS_SEED_OLD"
new_wallet_env = "HARNESS_SEED_NEW"
payment_processor_env = "HARNESS_SEED_PP"
wallet_password_env = "HARNESS_WALLET_PW"

[modes]
old_wallet_grpc_address = "http://127.0.0.1:18143"
new_wallet_database = ".bench-data/new-wallet/wallet.db"
payment_processor_listen = "127.0.0.1:9145"
payment_receiver_listen = "127.0.0.1:9146"

[versions]
minotari_cli_rev = "360c4848a54d65fd710266233cc9277b0f785e74"
tari_console_wallet_rev = "9f5adb7183dc2ec285f5c8fae05f4be9735d9749"
payment_processor_rev = "f0572c98cbfac7377412dc6d4094c7d7dfc5de2c"

# Optional: record funding evidence after sending Esmeralda funds to the
# generated addresses. These are benchmark inputs, not secrets.
#
# [funding.old_wallet]
# amount = "50000 T"
# tx_id = "11463237927696771510"
# height = 707731
#
# [funding.new_wallet]
# amount = "50000 T"
# tx_id = "7676530785144502866"
# height = 707741
#
# [funding.payment_processor]
# amount = "50000 T"
# tx_id = "4002233626181090692"
# height = 707747

[timeouts]
startup_secs = 1800
confirmation_secs = 1200
scan_batch_secs = 300
transaction_lock_secs = 60
