    "build_manifest": {
      "additionalProperties": false,
      "properties": {
        "artifacts": {
          "additionalProperties": {
            "$ref": "#/$defs/build_artifact"
          },
          "minProperties": 1,
          "type": "object"
        },
        "payment_processor_patch_sha256": {
          "minLength": 1,
          "type": "string"
        },
        "schema_version": {
          "minimum": 1,
          "type": "integer"
        },
        "sources": {
          "type": "object"
        }
      },
      "required": [
        "schema_version",
        "artifacts"
      ],
      "type": "object"
    },
    "chain_verification": {
      "additionalProperties": false,
      "properties": {
        "tx_mined_confirmed_status_value": {
          "const": 6
        },
        "verified_transactions": {
          "items": {
            "$ref": "#/$defs/verified_transaction"
          },
          "type": "array"
        }
      },
      "required": [
        "tx_mined_confirmed_status_value",
        "verified_transactions"
      ],
      "type": "object"
    },
    "computed_deltas": {
      "additionalProperties": false,
      "properties": {
        "s5_throughput": {
          "additionalProperties": false,
          "properties": {
            "arms": {
              "additionalProperties": true,
              "type": "object"
            },
            "comparison_unavailable_reasons": {
              "additionalProperties": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "type": "object"
            },
            "comparisons": {
              "additionalProperties": {
                "type": [
                  "number",
                  "null"
                ]
              },
              "type": "object"
            },
            "source": {
              "type": "string"
            }
          },
          "required": [
            "arms",
            "comparisons",
            "comparison_unavailable_reasons",
            "source"
          ],
          "type": "object"
        },
        "scan_deltas": {
          "additionalProperties": true,
          "type": "object"
        }
      },
      "required": [
        "scan_deltas",
        "s5_throughput"
      ],
      "type": "object"
    },
    "config": {
      "additionalProperties": true,
      "properties": {
        "A_fund": {
          "type": "string"
        },
        "C_min": {
          "minimum": 1,
