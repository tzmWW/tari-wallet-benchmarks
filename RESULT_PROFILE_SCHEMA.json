        "authority_tip_end_height": {
          "$ref": "#/$defs/nullable_integer"
        },
        "authority_tip_start_hash": {
          "$ref": "#/$defs/nullable_string"
        },
        "authority_tip_start_height": {
          "$ref": "#/$defs/nullable_integer"
        },
        "configured_revision": {
          "minLength": 1,
          "type": "string"
        },
        "endpoint": {
          "minLength": 1,
          "type": "string"
        },
        "is_synced": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "observed_version": {
          "$ref": "#/$defs/nullable_string"
        },
        "pruning_horizon": {
          "$ref": "#/$defs/nullable_integer"
        },
        "tip_end_hash": {
          "$ref": "#/$defs/nullable_string"
        },
        "tip_end_height": {
          "$ref": "#/$defs/nullable_integer"
        },
        "tip_start_hash": {
          "$ref": "#/$defs/nullable_string"
