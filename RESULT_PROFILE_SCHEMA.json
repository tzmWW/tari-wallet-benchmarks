        },
        "S4_T_budget_secs": {
          "minimum": 1,
          "type": "integer"
        },
        "S5_K": {
          "minimum": 1,
          "type": "integer"
        },
        "S5_M": {
          "minimum": 1,
          "type": "integer"
        },
        "concurrent_batches": {
          "items": {
            "minimum": 1,
            "type": "integer"
          },
          "minItems": 1,
          "type": "array",
