        "doubling_rounds": {
          "minimum": 1,
          "type": "integer"
        },
        "fanout_outputs_per_tx": {
          "minimum": 1,
          "type": "integer"
        },
        "fee_rate": {
          "type": "string"
        },
        "protocol_fingerprint": {
          "minLength": 64,
          "type": "string"
        },
        "scan_repetitions": {
          "minimum": 1,
          "type": "integer"
        },
        "volume_target": {
          "minimum": 1,
          "type": "integer"
        }
      },
      "required": [
        "A_fund",
        "C_min",
        "volume_target",
        "doubling_rounds",
        "fanout_outputs_per_tx",
        "concurrent_batches",
        "S4_T_budget_secs",
        "S5_M",
        "S5_K",
        "fee_rate",
        "scan_repetitions",
        "protocol_fingerprint"
      ],
      "type": "object"
    },
    "environment": {
      "additionalProperties": false,
      "properties": {
        "authority_host": {
          "type": "string"
