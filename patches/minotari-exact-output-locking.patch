+    /// Locks one caller-selected spendable output for an exact no-change transaction.
+    #[allow(clippy::too_many_arguments)]
+    pub fn lock_specific_output(
+        &self,
+        account_id: i64,
+        output_id: i64,
+        amount: MicroMinotari,
+        fee: MicroMinotari,
+        idempotency_key: Option<String>,
+        seconds_to_lock_utxos: u64,
+        confirmation_window: u64,
+    ) -> Result<LockFundsResult, anyhow::Error> {
+        let mut conn = self.db_pool.get()?;
+        if let Some(idempotency_key_str) = &idempotency_key
+            && let Some(response) =
+                db::find_pending_transaction_locked_funds_by_idempotency_key(&conn, idempotency_key_str, account_id)?
+        {
+            return Ok(response);
+        }
+
+        let _guard = FUND_LOCK_MUTEX
+            .lock()
+            .expect("Fund locker mutex poisoned - a prior lock call panicked");
+        if let Some(idempotency_key_str) = &idempotency_key
+            && let Some(response) =
+                db::find_pending_transaction_locked_funds_by_idempotency_key(&conn, idempotency_key_str, account_id)?
+        {
+            return Ok(response);
+        }
+
+        let tip_height = db::get_latest_scanned_tip_block_by_account(&conn, account_id)?
+            .map(|tip| tip.height)
+            .unwrap_or_default();
+        let min_height = tip_height.saturating_sub(confirmation_window);
+        let output = db::fetch_unspent_outputs(&conn, account_id, min_height, tip_height)?
+            .into_iter()
+            .find(|output| output.id == output_id)
+            .ok_or_else(|| anyhow::anyhow!("output {output_id} is not spendable for account {account_id}"))?;
+        let required = amount
+            .checked_add(fee)
+            .ok_or_else(|| anyhow::anyhow!("specific-output amount and fee overflow"))?;
+        if output.output.value() != required {
+            anyhow::bail!(
+                "specific output {} has value {}, expected exact no-change total {}",
+                output_id,
+                output.output.value(),
+                required
+            );
+        }
+
+        let transaction = conn.transaction()?;
+        #[allow(clippy::cast_possible_wrap)]
+        let expires_at = Utc::now() + Duration::seconds(seconds_to_lock_utxos as i64);
+        let idempotency_key = idempotency_key.unwrap_or_else(|| Uuid::new_v4().to_string());
+        let pending_tx_id = db::create_pending_transaction(
+            &transaction,
+            &idempotency_key,
+            account_id,
+            false,
+            output.output.value(),
+            fee,
+            fee,
+            expires_at,
+        )?;
+        if !db::lock_output(&transaction, output.id, &pending_tx_id, expires_at)? {
+            anyhow::bail!("specific output {} was no longer unspent", output.id);
+        }
+        transaction.commit()?;
+
+        Ok(LockFundsResult {
+            utxos: vec![output.output],
+            requires_change_output: false,
+            total_value: required,
+            fee_without_change: fee,
+            fee_with_change: fee,
+        })
+    }
 }
 
