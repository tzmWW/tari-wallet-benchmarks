+
+    #[test]
+    fn lock_specific_output_locks_only_requested_parent() {
+        let (pool, account_id, _temp) = setup_test_env(3, 1_000_000);
+        let output_id: i64 = pool
+            .get()
+            .expect("connection")
+            .query_row("SELECT id FROM outputs WHERE value = 2000000", [], |row| row.get(0))
+            .expect("target output");
+
+        let result = FundLocker::new(pool.clone())
+            .lock_specific_output(
+                account_id,
+                output_id,
+                MicroMinotari(1_999_340),
+                MicroMinotari(660),
+                Some("specific-parent".to_string()),
+                3600,
+                100,
+            )
+            .expect("specific lock succeeds");
+
+        assert_eq!(result.utxos.len(), 1);
+        assert_eq!(result.utxos[0].value(), MicroMinotari(2_000_000));
+        assert!(!result.requires_change_output);
+        assert_eq!(result.fee_without_change, MicroMinotari(660));
+        let conn = pool.get().expect("connection");
+        let locked_id: i64 = conn
+            .query_row("SELECT id FROM outputs WHERE status = 'LOCKED'", [], |row| row.get(0))
+            .expect("locked output");
+        assert_eq!(locked_id, output_id);
+    }
+
+    #[test]
+    fn lock_specific_output_rejects_non_exact_or_unspendable_parent_atomically() {
+        let (pool, account_id, _temp) = setup_test_env(1, 1_000_000);
+        let output_id: i64 = pool
+            .get()
+            .expect("connection")
+            .query_row("SELECT id FROM outputs", [], |row| row.get(0))
+            .expect("target output");
+        let locker = FundLocker::new(pool.clone());
+
+        let error = locker
+            .lock_specific_output(
+                account_id,
+                output_id,
+                MicroMinotari(999_000),
+                MicroMinotari(500),
+                None,
+                3600,
+                100,
+            )
+            .expect_err("non-exact total must fail");
+        assert!(error.to_string().contains("expected exact no-change total"));
+        let conn = pool.get().expect("connection");
+        let pending: i64 = conn
+            .query_row("SELECT COUNT(*) FROM pending_transactions", [], |row| row.get(0))
+            .expect("pending count");
+        let locked: i64 = conn
+            .query_row("SELECT COUNT(*) FROM outputs WHERE status = 'LOCKED'", [], |row| {
+                row.get(0)
+            })
+            .expect("locked count");
+        assert_eq!(pending, 0);
+        assert_eq!(locked, 0);
+    }
 }
