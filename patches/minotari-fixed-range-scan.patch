+#[cfg(test)]
+mod tests {
+    use super::inclusive_partial_end;
+
+    #[test]
+    fn partial_end_height_is_inclusive() {
+        assert_eq!(inclusive_partial_end(751_501, 14), 751_514);
+        assert_eq!(inclusive_partial_end(10, 1), 10);
+        assert_eq!(inclusive_partial_end(u64::MAX - 1, 10), u64::MAX);
+    }
