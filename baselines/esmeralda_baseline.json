  "findings": [
    {
      "id": "pp-real-app",
      "title": "Mode 3 uses the real minotari_payment_processor",
      "status": "implemented_in_topology",
      "recommendation": "Keep PP failures visible as benchmark output rather than bypassing the service."
    },
    {
      "id": "birthday-seeds",
      "title": "Genesis and birthday scans require birthday-encoded seeds",
      "status": "harness_generates_seed_material",
      "recommendation": "Use generated seeds and rewrite birthday for scan setup instead of RescanWallet(0)."
    },
    {
      "id": "chain-verification",
      "title": "Mempool acceptance is not benchmark success",
      "status": "schema_requires_chain_verification",
      "recommendation": "Verify claimed successful transactions with status value 6 before publishing throughput."
    },
    {
      "id": "funds-pending-hidden-state",
      "title": "FundsPending can live outside reported balances",
      "status": "observed_in_live_runs",
      "recommendation": "Use chain-advance settlement gates between planned spend rounds; do not retry failed sends."
    },
    {
      "id": "mode2-single-recipient-library-limit",
      "title": "Pinned Mode 2 library path is single-recipient for direct sends",
      "status": "reported_as_wallet_surface_limit",
      "recommendation": "Use the real multi-recipient CLI/API path when available and record unsupported behavior explicitly."
    },
    {
      "id": "pp-single-utxo-lock-stalls-batches",
      "title": "Payment processor batches can stall behind one locked UTXO",
      "status": "observed_in_real_topology",
      "recommendation": "Preserve PENDING_BATCHING/insufficient-funds states as benchmark signal."
    },
    {
      "id": "console-mnemonic-birthday",
      "title": "Console wallet recovery uses mnemonic birthday over the birthday flag",
      "status": "implemented_in_mode1_startup",
      "recommendation": "Rewrite only the mnemonic birthday for birthday scans while preserving wallet keys and address."
    }
  ],
